{
  "name": "couch-ops",
  "version": "0.1.0",
  "private": true,
  "description": "Internal operations tool for the couch business (inventory, trips, sales).",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "node --env-file=.env src/server.js",
